FROM node:20-alpine

# Install curl for healthcheck
RUN apk add --no-cache curl

WORKDIR /app

# Install dependencies for hardhat and ethers
RUN npm install -g npm

COPY package*.json ./
RUN npm ci

COPY . .

# Expose Hardhat default port
EXPOSE 8545

# Start Hardhat node with chain ID 31337 (local dev)
CMD ["npx", "hardhat", "node", "--hostname", "0.0.0.0", "--port", "8545"]